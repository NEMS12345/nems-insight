# NEMS Insight — environment variables
# Copy this file to `.env.local` (which is git-ignored) and fill in real values.
# NEVER commit real secrets. Production values go in Vercel's environment settings.

# --- Supabase ---
# Found in Supabase: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only key with elevated privileges. NEVER expose to the browser and NEVER
# prefix with NEXT_PUBLIC_. Used only in trusted server code (e.g. ingestion).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
